BOT_NAME=My Briefing Bot
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/REPLACE/ME

# 공통 설정 가이드 기준: 날씨/미세먼지는 self-host 또는 배포 검증된 proxy URL 권장
# 예: https://your-proxy.example.com
KSKILL_PROXY_BASE_URL=
BRIEFING_TIMEZONE=Asia/Seoul
BRIEFING_CRON=30 7 * * *
BRIEFING_RUN_ONCE=false

BRIEFING_LAT=37.5258
BRIEFING_LON=126.8966
BRIEFING_REGION_HINT=서울 영등포구
BRIEFING_WEATHER_TARGET_TIME=0800
